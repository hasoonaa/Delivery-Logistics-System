<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane
    xmlns:fx="http://javafx.com/fxml/1"
    xmlns="http://javafx.com/javafx/17"
    fx:controller="GroupProjectB.Delivery.and.Logistics.AdminLoginController"
    prefWidth="800" prefHeight="500"
    styleClass="root-pane"
    stylesheets="@style.css">

    <!-- Page Title -->
    <Label
        text="Admin login"
        styleClass="page-title"
        AnchorPane.topAnchor="60"
        AnchorPane.leftAnchor="0"
        AnchorPane.rightAnchor="0" />

    <!-- White Card -->
    <VBox
        styleClass="card"
        spacing="14"
        AnchorPane.topAnchor="130"
        AnchorPane.leftAnchor="210"
        AnchorPane.rightAnchor="210">

        <padding>
            <Insets top="28" right="28" bottom="28" left="28"/>
        </padding>

        <!-- Username -->
        <Label text="Username" styleClass="field-label"/>
        <TextField
            fx:id="usernameField"
            promptText="Enter Username"
            styleClass="input-field"/>

        <!-- Password -->
        <Label text="Password" styleClass="field-label"/>
        <PasswordField
            fx:id="passwordField"
            promptText="Enter Password"
            styleClass="input-field"/>

        <!-- Login Button -->
        <Button
            fx:id="loginButton"
            text="Login"
            styleClass="login-btn"
            maxWidth="Infinity"
            onAction="#handleLogin"/>

        <!-- Forgot Password -->
        <Hyperlink
            fx:id="forgotLink"
            text="Forgot password?"
            styleClass="forgot-link"
            onAction="#handleForgotPassword"/>
            
        <!-- Back arrow button -->   
        <Button
    		text="← Back"
    		styleClass="back-btn"
    		onAction="#handleBack"
    		AnchorPane.topAnchor="16"
    		AnchorPane.leftAnchor="16"/>
            

    </VBox>
</AnchorPane>
