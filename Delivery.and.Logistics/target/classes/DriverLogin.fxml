<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane
    fx:id="rootPane"
    xmlns:fx="http://javafx.com/fxml/1"
    xmlns="http://javafx.com/javafx/17"
    fx:controller="GroupProjectB.Delivery.and.Logistics.DriverLoginController"
    prefWidth="640" prefHeight="400"
    styleClass="root-pane"
    stylesheets="@style.css">

    <!-- Page Title -->
    <Label
        text="Driver login"
        styleClass="page-title"
        AnchorPane.topAnchor="30"
        AnchorPane.leftAnchor="0"
        AnchorPane.rightAnchor="0" />

    <!-- White Card Box -->
    <VBox
        styleClass="card"
        spacing="12"
        AnchorPane.topAnchor="80"
        AnchorPane.leftAnchor="180"
        AnchorPane.rightAnchor="180">

        <padding>
            <Insets top="20" right="20" bottom="20" left="20" />
        </padding>

        <!-- Username -->
        <Label text="Username" styleClass="field-label" />
        <TextField
            fx:id="usernameField"
            promptText="Enter Username"
            styleClass="input-field" />

        <!-- Password -->
        <Label text="Password" styleClass="field-label" />
        <PasswordField
            fx:id="passwordField"
            promptText="Enter Password"
            styleClass="input-field" />

        <!-- Sign In Button -->
        <Button
            fx:id="signInButton"
            text="Sign In"
            styleClass="login-btn"
            maxWidth="Infinity"
            onAction="#handleSignIn" />

        <!-- Forgot Password Link -->
        <Hyperlink
            fx:id="forgotLink"
            text="Forgot password?"
            styleClass="forgot-link"
            onAction="#handleForgotPassword" />
            
            
        <!-- Back arrow button -->   
        <Button
    		text="← Back"
    		styleClass="back-btn"
    		onAction="#handleBack"
    		AnchorPane.topAnchor="16"
    		AnchorPane.leftAnchor="16"/>
            


    </VBox>
</AnchorPane>
